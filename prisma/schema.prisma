// Hammer App — Prisma schema
// Phase 1: Technician onboarding (auth + 7-step KYC) + admin master data.
// See claude.md for the full data contract.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  NEED_CLARIFICATION
  NOT_COMPLETED
  REJECTED
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CompanyType {
  INDIVIDUAL
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LIMITED
  LLP
}

// Shop firm type (mobile app sends proprietorship | partnership | privatelimited)
enum FirmType {
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LIMITED
}

enum BankAccountType {
  SAVINGS
  CURRENT
}

// ─────────────────────────────────────────────────────────────
// Technician (core mobile user)
// ─────────────────────────────────────────────────────────────

model Technician {
  id     String        @id @default(cuid())
  // Public unique ID e.g. T2607040001 — {T}{YYMMDD}{sequence:4}
  code   String        @unique
  name   String?
  mobile String        @unique
  email  String?
  status AccountStatus @default(INACTIVE)

  // Overall onboarding KYC status (rolls up the 5 legal steps)
  kycStatus KycStatus @default(NOT_STARTED)

  // FCM token for push notifications
  fcmToken String?

  // Last Aadhaar–PAN linkage check (via verify.ts adapter)
  aadharPanLinked    Boolean?
  aadharPanCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personalKyc       PersonalKyc?
  education         EducationQualification?
  bankKyc           BankKyc?
  companyKyc        CompanyKyc?
  documents         DocumentKyc[]
  signature         Signature?
  serviceCategories TechnicianServiceCategory[]
  otps              Otp[]

  @@index([mobile])
  @@index([kycStatus])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// OTP verification
// ─────────────────────────────────────────────────────────────

model Otp {
  id           String     @id @default(cuid())
  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  mobile    String
  code      String
  purpose   String   @default("LOGIN") // LOGIN | REGISTER | FORGOT_PASSWORD
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([technicianId])
  @@index([mobile, code])
}

// ─────────────────────────────────────────────────────────────
// KYC Step 1: Personal
// ─────────────────────────────────────────────────────────────

model PersonalKyc {
  id           String     @id @default(cuid())
  technicianId String     @unique
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  fullName     String?
  dob          DateTime?
  gender       Gender?
  bloodGroupId String?
  bloodGroup   BloodGroup? @relation(fields: [bloodGroupId], references: [id])

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  profilePhoto String?

  status KycStatus @default(NOT_STARTED)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// KYC Step 2: Education
// ─────────────────────────────────────────────────────────────

model EducationQualification {
  id           String     @id @default(cuid())
  technicianId String     @unique
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  qualification   String?
  institution     String?
  yearOfPassing   Int?
  certificateFile String?

  status KycStatus @default(NOT_STARTED)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// KYC Step 3: Service categories (many-to-many via join model)
// ─────────────────────────────────────────────────────────────

model TechnicianServiceCategory {
  id           String     @id @default(cuid())
  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  serviceCategoryId String
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)

  // Optional supporting certificate for this service
  certificateId   String?
  certificate     Certificate? @relation(fields: [certificateId], references: [id])
  certificateFile String?

  status    KycStatus @default(PENDING)
  createdAt DateTime  @default(now())

  @@unique([technicianId, serviceCategoryId])
  @@index([technicianId])
}

// ─────────────────────────────────────────────────────────────
// Bank KYC
// ─────────────────────────────────────────────────────────────

model BankKyc {
  id           String     @id @default(cuid())
  technicianId String     @unique
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  accountHolder String?
  accountNumber String?
  ifsc          String?
  bankName      String?
  branch        String?
  upiId         String?
  passbookFile  String? @map("passbook_file")

  status KycStatus @default(NOT_STARTED)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Company / Firm KYC
// ─────────────────────────────────────────────────────────────

model CompanyKyc {
  id           String     @id @default(cuid())
  technicianId String     @unique
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  companyType        CompanyType @default(INDIVIDUAL)
  companyName        String?
  gstNumber          String?
  gstVerified        Boolean     @default(false)
  panNumber          String?
  registrationNumber String?

  status KycStatus @default(NOT_STARTED)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Document KYC (multiple docs: Aadhaar, PAN, etc.)
// ─────────────────────────────────────────────────────────────

model DocumentKyc {
  id           String     @id @default(cuid())
  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  docType   String // AADHAAR | PAN | DRIVING_LICENSE | ...
  docNumber String?
  frontFile String?
  backFile  String?

  status KycStatus @default(PENDING)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([technicianId])
}

// ─────────────────────────────────────────────────────────────
// Signature
// ─────────────────────────────────────────────────────────────

model Signature {
  id           String     @id @default(cuid())
  technicianId String     @unique
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  file      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Master data (admin-managed)
// ─────────────────────────────────────────────────────────────

model ServiceCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  technicianLinks TechnicianServiceCategory[]
  certificates    Certificate[]
  subcategories   ServiceSubcategory[]
  services        Service[]
}

// Level 2 of the services taxonomy (e.g. "New Wiring" under "Electrician").
model ServiceSubcategory {
  id                String          @id @default(cuid())
  name              String
  serviceCategoryId String
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  services Service[]

  @@unique([serviceCategoryId, name])
  @@index([serviceCategoryId])
}

// Level 3: an individual bookable service with tax + SAC code (customer-facing).
model Service {
  id                   String              @id @default(cuid())
  name                 String
  serviceCategoryId    String
  serviceCategory      ServiceCategory     @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)
  serviceSubcategoryId String?
  serviceSubcategory   ServiceSubcategory? @relation(fields: [serviceSubcategoryId], references: [id])

  taxPercent Float   @default(0) // GST %, e.g. 5 / 12 / 18
  sacCode    String? // SAC/HSN code for billing
  image      String?
  active     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceCategoryId, serviceSubcategoryId, name])
  @@index([serviceCategoryId])
  @@index([serviceSubcategoryId])
}

model Certificate {
  id                String           @id @default(cuid())
  name              String
  serviceCategoryId String?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  active            Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  technicianLinks TechnicianServiceCategory[]
}

model Location {
  id        String   @id @default(cuid())
  name      String
  city      String?
  state     String?
  pincode   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personalKycs PersonalKyc[]
}

model Badge {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  icon      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RejectReason {
  id        String   @id @default(cuid())
  reason    String
  category  String? // which KYC step it applies to
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BloodGroup {
  id        String   @id @default(cuid())
  name      String   @unique // A+, A-, O+, ...
  createdAt DateTime @default(now())

  personalKycs     PersonalKyc[]
  shopPersonalKycs ShopPersonalKyc[]
}

// ─────────────────────────────────────────────────────────────
// SHOP (Phase 2) — mobile user for the Hammer Shop Flutter app.
//
// ⚠️ Mobile contract differences vs Technician (verified against
// techtogrowindia/hammer_shop):
//   • Response envelope key is `success` (not `status`), token at top level.
//   • `id` is exposed to the app as an integer → Shop uses Int PK,
//     `code` (S{YYMMDD}{seq}) is the `unique_id`.
//   • Password auth (create takes password, login = mobile+password),
//     OTP only verifies the mobile number.
//   • `product_category_id` / `product_subcategory_id` are integers.
// ─────────────────────────────────────────────────────────────

model Shop {
  id             Int           @id @default(autoincrement())
  code           String        @unique // S{YYMMDD}{seq} — exposed as unique_id
  name           String?
  mobile         String        @unique
  email          String?
  password       String? // bcrypt hash
  status         AccountStatus @default(INACTIVE)
  mobileVerified Boolean       @default(false)

  kycStatus KycStatus @default(NOT_STARTED)

  // ₹ one-time non-refundable registration fee (Razorpay). Gates activation.
  registrationPaid Boolean @default(false)

  fcmToken String?

  // Last Aadhaar–PAN linkage check (via verify.ts adapter)
  aadharPanLinked    Boolean?
  aadharPanCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personalKyc       ShopPersonalKyc?
  companyKyc        ShopCompanyKyc?
  bankKyc           ShopBankKyc?
  partners          ShopPartner[]
  productCategories ShopProductCategory[]
  documents         ShopDocumentKyc[]
  signature         ShopSignature?
  otps              ShopOtp[]
  payments          ShopPayment[]

  @@index([mobile])
  @@index([kycStatus])
  @@index([status])
}

model ShopOtp {
  id     String @id @default(cuid())
  shopId Int
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  mobile    String
  code      String
  purpose   String   @default("LOGIN") // LOGIN | REGISTER | FORGOT_PASSWORD | MOBILE_VERIFY | KYC_FINAL_VERIFICATION
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([mobile, code])
}

model ShopPersonalKyc {
  id     String @id @default(cuid())
  shopId Int    @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name         String?
  dob          DateTime?
  bloodGroupId String?
  bloodGroup   BloodGroup? @relation(fields: [bloodGroupId], references: [id])
  aadharNumber String?
  panNumber    String?
  firmType     FirmType?
  businessPan  String?

  address         String?
  cityTownVillage String?
  taluk           String?
  district        String?
  pincode         String?

  profilePhoto String?

  status KycStatus @default(NOT_STARTED)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopPartner {
  id     String @id @default(cuid())
  shopId Int
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name      String
  panNumber String?
  createdAt DateTime @default(now())

  @@index([shopId])
}

model ShopCompanyKyc {
  id     String @id @default(cuid())
  shopId Int    @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  hasGst      Boolean @default(false)
  gstNumber   String?
  gstVerified Boolean @default(false)
  legalName   String?

  companyName       String?
  companyAddress    String?
  cityTownVillage   String?
  taluk             String?
  district          String?
  companyPincode    String?
  numberOfEmployees Int?

  status KycStatus @default(NOT_STARTED)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopBankKyc {
  id     String @id @default(cuid())
  shopId Int    @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  bankName      String?
  accountHolder String?
  accountNumber String?
  accountType   BankAccountType?
  ifsc          String?
  branch        String?
  upiId         String?
  passbookFile  String?

  status KycStatus @default(NOT_STARTED)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopDocumentKyc {
  id     String @id @default(cuid())
  shopId Int
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  docType   String // AADHAAR | PAN | BANK_PASSBOOK | PHOTO | GST | SHOP_PHOTO
  docNumber String?
  frontFile String?
  backFile  String?

  // Geotag for the shop photo with name board (LAT/LONG/TIME).
  latitude   Float?
  longitude  Float?
  capturedAt DateTime?

  status KycStatus @default(PENDING)
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

model ShopSignature {
  id     String @id @default(cuid())
  shopId Int    @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  file      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopPayment {
  // Int PK — exposed to the app as `order_id` (see payment-update contract).
  id     Int  @id @default(autoincrement())
  shopId Int
  shop   Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  provider  String    @default("RAZORPAY")
  purpose   String    @default("REGISTRATION_FEE")
  orderId   String?
  paymentId String?
  amount    Int // in paise
  currency  String    @default("INR")
  status    String    @default("CREATED") // CREATED | PAID | FAILED
  paidAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

// Product master data (int PK — mobile sends product_category_id as int).
model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  icon        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subcategories ProductSubcategory[]
  shopLinks     ShopProductCategory[]
}

model ProductSubcategory {
  id                Int             @id @default(autoincrement())
  name              String
  productCategoryId Int
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  shopLinks ShopProductCategory[]

  @@index([productCategoryId])
}

// Shop ↔ product category (max 3, enforced in the API/UI).
model ShopProductCategory {
  id     String @id @default(cuid())
  shopId Int
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  productCategoryId Int
  productCategory   ProductCategory @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)

  productSubcategoryId Int?
  productSubcategory   ProductSubcategory? @relation(fields: [productSubcategoryId], references: [id])

  status    KycStatus @default(PENDING)
  createdAt DateTime  @default(now())

  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// Admin (NextAuth credentials)
// ─────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN | SUPER_ADMIN | REVIEWER
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
